# Local development (npm run db:start uses embedded PostgreSQL):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/maxey?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5433/maxey?schema=public"

# Production — Supabase Postgres. From your Supabase project:
# Settings -> Database -> Connection string
#   DATABASE_URL = "Transaction" pooler string (port 6543) — used by the running app
#   DIRECT_URL   = direct connection string (port 5432) — used only when running
#                  `prisma migrate` (pooled connections can't run migrations)
# Fill these in directly in your own .env / hosting provider's env settings —
# never paste a database password into chat.
DATABASE_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-string"

# Supabase Storage — photo/receipt uploads go to a PRIVATE bucket, served via
# the authenticated /api/files proxy. Required before deploying to Vercel (its
# filesystem is ephemeral). When unset, uploads fall back to local public/uploads.
# Service-role key is server-side only — never expose it to the browser.
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="uploads"

# SMS gateway (PH) — Semaphore
# SEMAPHORE_API_KEY=""
# Email — Resend
# RESEND_API_KEY=""
